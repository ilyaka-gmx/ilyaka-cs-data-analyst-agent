# Nebius Token Factory API Key (required)
# Get yours at: https://tokenfactory.nebius.com/
NEBIUS_API_KEY=your_api_key_here

# API Base URL (optional — default works for most accounts)
# NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/

# Model IDs (optional — defaults below work with most accounts)
# Change these if your account doesn't have access to the default models
# AGENT_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# ROUTER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# JUDGE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Quality scoring (optional — disabled by default)
# ENABLE_QUALITY_SCORING=false
