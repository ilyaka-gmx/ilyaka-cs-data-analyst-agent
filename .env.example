# Nebius Token Factory API Key (required)
# Get yours at: https://tokenfactory.nebius.com/
NEBIUS_API_KEY=your_api_key_here

# API Base URL (optional — default works for most accounts)
# NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/

# Model IDs (optional — defaults below work with most accounts)
# Change these if your account doesn't have access to the default models
# AGENT_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# ROUTER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# JUDGE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Mem0 semantic memory models (optional — defaults below)
# MEM0_LLM_MODEL uses the same Nebius API key; handles fact extraction
# EMBEDDING_MODEL handles vector embeddings for semantic search
# MEM0_LLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# Mem0 storage path (optional — default: mem0_data under project root)
# Relative paths resolve against the project root; absolute paths used as-is.
# MEM0_STORAGE_PATH=mem0_data
# MEM0_STORAGE_PATH=/var/data/my-agent-mem0

# Quality scoring (optional — disabled by default)
# ENABLE_QUALITY_SCORING=false

# Reflection step — self-check before final response (default: true)
# When enabled, a lightweight LLM call checks if the agent gave a "lazy" answer
# and nudges it to try harder. Adds ~1 extra LLM call per response.
# ENABLE_REFLECTION=true

# Query decomposition — pre-execution planning for free-text queries (default: true)
# When enabled, a lightweight LLM call decomposes ambiguous queries into a
# step-by-step plan before the agent starts its ReAct loop.
# Adds ~1 extra LLM call per query (uses the cheap router model).
# ENABLE_DECOMPOSITION=true
